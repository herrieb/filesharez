<!DOCTYPE html>
<html lang="en" class="h-full" data-theme="{{ app.request.attributes.get('_theme_id', 'longhorn') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}FileShareZ{% endblock %}</title>
    <meta name="description" content="Secure file sharing platform">
    <meta name="theme-color" content="{{ app.request.attributes.get('_theme').slateBase }}">
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.10/dist/cdn.min.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        slate: { base: '#1B1E24', surface: '#2A2F38', deep: '#101217' },
                        aero: { DEFAULT: '#6CB2FF', dim: '#3A7BD5', glow: '#8EC5FF' },
                        success: '#10B981',
                        danger: '#EF4444',
                        warn: '#F59E0B',
                    },
                }
            }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
    {{ theme_block()|raw }}
    <style>
        *, *::before, *::after { box-sizing: border-box; }

        body {
            background-color: var(--slate-deep);
            background-image:
                var(--ambient-glow-1),
                var(--ambient-glow-2),
                var(--body-gradient);
            background-attachment: fixed;
            background-size: cover;
            background-repeat: no-repeat;
            font-family: var(--font-family);
            color: #E5E7EB;
            min-height: 100vh;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.02'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 0;
        }

        .glass {
            background: rgba(255,255,255,0.08);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255,255,255,0.14);
            border-radius: 24px;
            box-shadow: 0 12px 40px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.12);
        }

        .glass-heavy {
            background: rgba(60,65,75,0.45);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid rgba(255,255,255,0.18);
            border-radius: 24px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.12);
        }

        .glass-light {
            background: rgba(255,255,255,0.04);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 20px;
        }

        .glass-panel {
            background: rgba(255,255,255,0.06);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 16px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.1);
        }

        .aero-btn {
            background: linear-gradient(180deg, rgba(255,255,255,0.22), rgba(255,255,255,0.06));
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 14px;
            color: #E5E7EB;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 16px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.15);
            cursor: pointer;
        }
        .aero-btn:hover {
            background: linear-gradient(180deg, rgba(255,255,255,0.3), rgba(255,255,255,0.1));
            box-shadow: 0 0 24px rgba(var(--accent-rgb), 0.3), 0 4px 16px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.2);
            color: #fff;
            transform: translateY(-1px);
        }
        .aero-btn:active { transform: translateY(0); }

        .aero-btn-primary {
            background: linear-gradient(180deg, rgba(var(--accent-rgb), 0.35), rgba(var(--accent-rgb), 0.12));
            border: 1px solid rgba(var(--accent-rgb), 0.35);
            border-radius: 14px;
            color: var(--accent-glow);
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 0 20px rgba(var(--accent-rgb), 0.2), 0 4px 16px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.12);
            cursor: pointer;
        }
        .aero-btn-primary:hover {
            background: linear-gradient(180deg, rgba(var(--accent-rgb), 0.5), rgba(var(--accent-rgb), 0.2));
            box-shadow: 0 0 30px rgba(var(--accent-rgb), 0.4), 0 4px 16px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.2);
            color: #fff;
            transform: translateY(-1px);
        }

        .form-input {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 10px;
            color: #E5E7EB;
            padding: 11px 16px;
            transition: all 0.25s ease;
        }
        .form-input:focus {
            outline: none;
            border-color: rgba(var(--accent-rgb), 0.5);
            box-shadow: 0 0 16px rgba(var(--accent-rgb), 0.15), inset 0 1px 0 rgba(255,255,255,0.08);
            background: rgba(255,255,255,0.09);
        }
        .form-input::placeholder { color: rgba(255,255,255,0.25); }

        .taskbar {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(60,65,75,0.45);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid rgba(255,255,255,0.18);
            border-radius: 20px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.12);
            padding: 8px 12px;
            z-index: 100;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .taskbar-desktop { display: none; }
        @media (min-width: 768px) {
            .taskbar-desktop { display: flex; }
        }

        .taskbar-item {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 8px 14px;
            border-radius: 12px;
            color: rgba(255,255,255,0.55);
            font-size: 13px;
            font-weight: 500;
            transition: all 0.25s ease;
            text-decoration: none;
            white-space: nowrap;
        }
        .taskbar-item:hover {
            background: rgba(255,255,255,0.1);
            color: var(--accent-glow);
            box-shadow: 0 0 12px rgba(var(--accent-rgb), 0.15);
        }
        .taskbar-item.active {
            background: rgba(var(--accent-rgb), 0.15);
            color: var(--accent-glow);
            box-shadow: 0 0 16px rgba(var(--accent-rgb), 0.2);
        }

        .taskbar-orb {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(var(--accent-rgb), 0.3), rgba(var(--accent-rgb), 0.1));
            border: 1px solid rgba(var(--accent-rgb), 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 8px;
            transition: all 0.3s ease;
            box-shadow: 0 0 16px rgba(var(--accent-rgb), 0.15), inset 0 1px 0 rgba(255,255,255,0.15);
            cursor: pointer;
            flex-shrink: 0;
        }
        .taskbar-orb:hover {
            background: linear-gradient(135deg, rgba(var(--accent-rgb), 0.5), rgba(var(--accent-rgb), 0.2));
            box-shadow: 0 0 24px rgba(var(--accent-rgb), 0.35), inset 0 1px 0 rgba(255,255,255,0.2);
        }

        .taskbar-divider {
            width: 1px;
            height: 28px;
            background: rgba(255,255,255,0.1);
            margin: 0 6px;
            flex-shrink: 0;
        }

        /* -------- Mobile bottom tab bar (iOS / Android feel) -------- */
        .mobile-tabbar {
            position: fixed;
            left: 0;
            right: 0;
            bottom: 0;
            z-index: 100;
            padding: 8px 8px calc(8px + env(safe-area-inset-bottom));
            background: linear-gradient(180deg, rgba(20,22,28,0.55), rgba(20,22,28,0.85));
            backdrop-filter: blur(28px) saturate(1.4);
            -webkit-backdrop-filter: blur(28px) saturate(1.4);
            border-top: 1px solid rgba(255,255,255,0.1);
            box-shadow: 0 -4px 24px rgba(0,0,0,0.4);
        }
        .mobile-tabbar-inner {
            display: flex;
            align-items: stretch;
            justify-content: space-around;
            gap: 2px;
        }
        .mobile-tab {
            flex: 1;
            min-width: 0;
            min-height: 56px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 3px;
            padding: 8px 4px;
            color: rgba(255,255,255,0.5);
            font-size: 10px;
            font-weight: 500;
            letter-spacing: 0.01em;
            text-decoration: none;
            background: none;
            border: 0;
            cursor: pointer;
            border-radius: 12px;
            position: relative;
            transition: color 0.2s ease, transform 0.15s ease;
            -webkit-tap-highlight-color: transparent;
        }
        .mobile-tab svg { width: 22px; height: 22px; }
        .mobile-tab span { line-height: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%; }
        .mobile-tab:active { transform: scale(0.92); }
        .mobile-tab.active { color: var(--accent-glow); }
        .mobile-tab.active::before {
            content: '';
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 24px;
            height: 3px;
            border-radius: 0 0 3px 3px;
            background: linear-gradient(180deg, var(--accent-glow), rgba(var(--accent-rgb), 0.3));
            box-shadow: 0 0 8px rgba(var(--accent-rgb), 0.5);
        }
        .mobile-tab.active svg { filter: drop-shadow(0 0 6px rgba(var(--accent-rgb), 0.5)); }

        /* -------- Mobile More sheet (iOS action sheet) -------- */
        .mobile-more-sheet {
            position: fixed;
            inset: 0;
            z-index: 200;
            display: flex;
            align-items: flex-end;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.2s ease;
        }
        .mobile-more-sheet.open { opacity: 1; pointer-events: auto; }
        .mobile-more-backdrop {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.55);
            backdrop-filter: blur(2px);
            -webkit-backdrop-filter: blur(2px);
        }
        .mobile-more-panel {
            position: relative;
            width: 100%;
            margin: 0 8px 8px;
            background: linear-gradient(180deg, rgba(40,44,52,0.95), rgba(28,30,36,0.95));
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 20px;
            box-shadow: 0 -8px 40px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.08);
            padding: 14px 12px calc(14px + env(safe-area-inset-bottom));
            transform: translateY(100%);
            transition: transform 0.32s cubic-bezier(0.32, 0.72, 0, 1);
            max-height: 80vh;
            overflow-y: auto;
        }
        .mobile-more-sheet.open .mobile-more-panel { transform: translateY(0); }
        .mobile-more-handle {
            width: 36px;
            height: 4px;
            background: rgba(255,255,255,0.25);
            border-radius: 999px;
            margin: 0 auto 12px;
        }
        .mobile-more-link {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 16px;
            color: rgba(255,255,255,0.85);
            text-decoration: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 500;
            transition: background 0.15s ease;
            -webkit-tap-highlight-color: transparent;
        }
        .mobile-more-link:active { background: rgba(255,255,255,0.08); }
        .mobile-more-link.active {
            background: rgba(var(--accent-rgb), 0.12);
            color: var(--accent-glow);
        }
        .mobile-more-link svg { flex-shrink: 0; }
        .mobile-more-divider {
            height: 1px;
            background: rgba(255,255,255,0.08);
            margin: 8px 4px;
        }

        .window-header {
            background: linear-gradient(180deg, rgba(255,255,255,0.08), transparent);
            border-bottom: 1px solid rgba(255,255,255,0.08);
            border-radius: 24px 24px 0 0;
            padding: 16px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .progress-bar-track {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 999px;
            overflow: hidden;
            height: 8px;
        }
        .progress-bar-fill {
            background: linear-gradient(90deg, var(--accent-primary), var(--accent-glow));
            border-radius: 999px;
            height: 100%;
            transition: width 0.4s ease;
            box-shadow: 0 0 12px rgba(var(--accent-rgb), 0.4);
            position: relative;
        }
        .progress-bar-fill::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(255,255,255,0.35), rgba(255,255,255,0.05));
            border-radius: 999px;
        }

        @keyframes fadeInBlur {
            from { opacity: 0; filter: blur(8px); transform: translateY(12px); }
            to { opacity: 1; filter: blur(0); transform: translateY(0); }
        }
        @keyframes pulseGlow {
            0%, 100% { box-shadow: 0 0 16px rgba(var(--accent-rgb), 0.1); }
            50% { box-shadow: 0 0 32px rgba(var(--accent-rgb), 0.25); }
        }
        @keyframes shimmer {
            0% { background-position: -200% center; }
            100% { background-position: 200% center; }
        }

        .animate-in {
            animation: fadeInBlur 0.6s ease forwards;
        }
        .animate-pulse-glow {
            animation: pulseGlow 3s ease-in-out infinite;
        }

        .drop-zone-active {
            border-color: rgba(var(--accent-rgb), 0.5) !important;
            background: rgba(var(--accent-rgb), 0.06) !important;
            box-shadow: 0 0 32px rgba(var(--accent-rgb), 0.15), inset 0 0 24px rgba(var(--accent-rgb), 0.05) !important;
        }

        .status-active { background: rgba(16,185,129,0.12); color: #10B981; border: 1px solid rgba(16,185,129,0.2); }
        .status-expired { background: rgba(239,68,68,0.1); color: #EF4444; border: 1px solid rgba(239,68,68,0.2); }
        .status-exhausted { background: rgba(245,158,11,0.1); color: #F59E0B; border: 1px solid rgba(245,158,11,0.2); }
        .status-revoked { background: rgba(239,68,68,0.1); color: #EF4444; border: 1px solid rgba(239,68,68,0.2); }
        .status-badge { padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; letter-spacing: 0.02em; }

        .table-responsive { overflow-x: auto; -webkit-overflow-scrolling: touch; }
        .table-responsive table { min-width: 640px; }
        .table-responsive th,
        .table-responsive td { white-space: nowrap; }
        .table-responsive th:first-child,
        .table-responsive td:first-child { white-space: normal; }

        @media (max-width: 640px) {
            .hide-sm { display: none !important; }
        }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
        ::-webkit-scrollbar-thumb { background: rgba(var(--accent-rgb), 0.2); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(var(--accent-rgb), 0.35); }

        @media (min-width: 768px) {
            .mobile-tabbar, .mobile-more-sheet { display: none !important; }
        }

        /* -------- Theme picker cards -------- */
        .theme-card {
            border-radius: 14px;
            padding: 14px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            cursor: pointer;
            transition: all 0.2s ease;
            font-family: var(--font-family);
        }
        .theme-card:hover {
            background: rgba(255,255,255,0.08);
            border-color: rgba(var(--accent-rgb), 0.3);
            transform: translateY(-1px);
        }
        .theme-card.active {
            border-color: rgba(var(--accent-rgb), 0.5);
            background: rgba(var(--accent-rgb), 0.08);
            box-shadow: 0 0 16px rgba(var(--accent-rgb), 0.2);
        }
        .theme-card-name { font-weight: 600; font-size: 14px; color: #fff; margin-bottom: 4px; }
        .theme-card-desc { font-size: 12px; color: rgba(255,255,255,0.5); margin-bottom: 10px; line-height: 1.4; }
        .theme-card-swatches { display: flex; gap: 6px; }
        .theme-card-swatches .swatch {
            display: inline-block;
            width: 24px; height: 24px;
            border-radius: 6px;
            border: 1px solid rgba(255,255,255,0.1);
        }

        /* -------- Sidebar layout (used by Tokyo, Aquarelle, Brutalist themes) -------- */
        .sidebar {
            width: 260px;
            flex-shrink: 0;
            position: sticky;
            top: 0;
            height: 100vh;
            overflow: hidden;
        }
        .sidebar-desktop { display: none; }
        .sidebar-inner {
            width: 100%;
            height: 100vh;
            position: relative;
        }
        .sidebar-orb {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(var(--accent-rgb), 0.3), rgba(var(--accent-rgb), 0.1));
            border: 1px solid rgba(var(--accent-rgb), 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            box-shadow: 0 0 16px rgba(var(--accent-rgb), 0.15), inset 0 1px 0 rgba(255,255,255,0.15);
        }
        .sidebar-orb svg { color: var(--accent-glow); }
        .sidebar-brand {
            color: rgba(255,255,255,0.55);
            font-weight: 600;
            font-size: 14px;
            letter-spacing: 0.05em;
        }
        .sidebar-brand-link {
            text-decoration: none;
        }
        .sidebar-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 14px;
            color: rgba(255,255,255,0.6);
            font-size: 13px;
            font-weight: 500;
            text-decoration: none;
            border-radius: 0 10px 10px 0;
            border-left: 2px solid transparent;
            transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
        }
        .sidebar-item:hover {
            background: rgba(var(--accent-rgb), 0.08);
            color: var(--accent-glow);
        }
        .sidebar-item.active {
            background: linear-gradient(90deg, rgba(var(--accent-rgb), 0.18), transparent 70%);
            border-left-color: var(--accent-primary);
            color: var(--accent-glow);
        }
        .sidebar-item.active svg { color: var(--accent-glow); }
        .sidebar-item svg { flex-shrink: 0; }
        .sidebar-divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(var(--accent-rgb), 0.2), transparent);
            margin: 0 12px;
        }
        .sidebar-section-label {
            color: rgba(var(--accent-rgb), 0.55);
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.18em;
            text-transform: uppercase;
        }
        .sidebar-signout {
            color: #EF4444;
            border-left-color: transparent;
        }
        .sidebar-signout:hover { background: rgba(239,68,68,0.1); color: #F87171; }

        @media (min-width: 768px) {
            .sidebar-desktop { display: flex; }
        }
        @media (max-width: 767px) {
            .sidebar-desktop { display: none; }
            .app-main { padding-top: 1.5rem; }
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body class="min-h-screen antialiased">
    {% block body %}{% endblock %}
    {% block javascripts %}{% endblock %}
</body>
</html>
