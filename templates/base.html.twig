<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}FileShareZ{% endblock %}</title>
    <meta name="description" content="Secure file sharing platform">
    <meta name="theme-color" content="#1B1E24">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        slate: { base: '#1B1E24', surface: '#2A2F38', deep: '#101217' },
                        aero: { DEFAULT: '#6CB2FF', dim: '#3A7BD5', glow: '#8EC5FF' },
                        success: '#10B981',
                        danger: '#EF4444',
                        warn: '#F59E0B',
                    },
                    fontFamily: {
                        sans: ['"Segoe UI"', 'Inter', 'Geist', 'system-ui', 'sans-serif'],
                    },
                }
            }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; }

        body {
            background: #101217;
            background-image:
                radial-gradient(circle at top left, rgba(120,170,255,0.12), transparent 35%),
                radial-gradient(circle at bottom right, rgba(255,255,255,0.04), transparent 25%),
                linear-gradient(180deg, #1B1E24 0%, #101217 100%);
            font-family: 'Segoe UI', 'Inter', system-ui, sans-serif;
            color: #E5E7EB;
            min-height: 100vh;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.02'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 0;
        }

        .glass {
            background: rgba(255,255,255,0.08);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255,255,255,0.14);
            border-radius: 24px;
            box-shadow: 0 12px 40px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.12);
        }

        .glass-heavy {
            background: rgba(60,65,75,0.45);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid rgba(255,255,255,0.18);
            border-radius: 24px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.12);
        }

        .glass-light {
            background: rgba(255,255,255,0.04);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 20px;
        }

        .glass-panel {
            background: rgba(255,255,255,0.06);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 16px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.1);
        }

        .aero-btn {
            background: linear-gradient(180deg, rgba(255,255,255,0.22), rgba(255,255,255,0.06));
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 14px;
            color: #E5E7EB;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 16px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.15);
            cursor: pointer;
        }
        .aero-btn:hover {
            background: linear-gradient(180deg, rgba(255,255,255,0.3), rgba(255,255,255,0.1));
            box-shadow: 0 0 24px rgba(108,178,255,0.3), 0 4px 16px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.2);
            color: #fff;
            transform: translateY(-1px);
        }
        .aero-btn:active { transform: translateY(0); }

        .aero-btn-primary {
            background: linear-gradient(180deg, rgba(108,178,255,0.35), rgba(108,178,255,0.12));
            border: 1px solid rgba(108,178,255,0.35);
            border-radius: 14px;
            color: #8EC5FF;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 0 20px rgba(108,178,255,0.2), 0 4px 16px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.12);
            cursor: pointer;
        }
        .aero-btn-primary:hover {
            background: linear-gradient(180deg, rgba(108,178,255,0.5), rgba(108,178,255,0.2));
            box-shadow: 0 0 30px rgba(108,178,255,0.4), 0 4px 16px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.2);
            color: #fff;
            transform: translateY(-1px);
        }

        .form-input {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 10px;
            color: #E5E7EB;
            padding: 11px 16px;
            transition: all 0.25s ease;
        }
        .form-input:focus {
            outline: none;
            border-color: rgba(108,178,255,0.5);
            box-shadow: 0 0 16px rgba(108,178,255,0.15), inset 0 1px 0 rgba(255,255,255,0.08);
            background: rgba(255,255,255,0.09);
        }
        .form-input::placeholder { color: rgba(255,255,255,0.25); }

        .taskbar {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(60,65,75,0.45);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid rgba(255,255,255,0.18);
            border-radius: 20px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.12);
            padding: 8px 12px;
            z-index: 100;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .taskbar-item {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 8px 14px;
            border-radius: 12px;
            color: rgba(255,255,255,0.55);
            font-size: 13px;
            font-weight: 500;
            transition: all 0.25s ease;
            text-decoration: none;
            white-space: nowrap;
        }
        .taskbar-item:hover {
            background: rgba(255,255,255,0.1);
            color: #8EC5FF;
            box-shadow: 0 0 12px rgba(108,178,255,0.15);
        }
        .taskbar-item.active {
            background: rgba(108,178,255,0.15);
            color: #8EC5FF;
            box-shadow: 0 0 16px rgba(108,178,255,0.2);
        }

        .taskbar-orb {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(108,178,255,0.3), rgba(108,178,255,0.1));
            border: 1px solid rgba(108,178,255,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 8px;
            transition: all 0.3s ease;
            box-shadow: 0 0 16px rgba(108,178,255,0.15), inset 0 1px 0 rgba(255,255,255,0.15);
            cursor: pointer;
            flex-shrink: 0;
        }
        .taskbar-orb:hover {
            background: linear-gradient(135deg, rgba(108,178,255,0.5), rgba(108,178,255,0.2));
            box-shadow: 0 0 24px rgba(108,178,255,0.35), inset 0 1px 0 rgba(255,255,255,0.2);
        }

        .taskbar-divider {
            width: 1px;
            height: 28px;
            background: rgba(255,255,255,0.1);
            margin: 0 6px;
            flex-shrink: 0;
        }

        .window-header {
            background: linear-gradient(180deg, rgba(255,255,255,0.08), transparent);
            border-bottom: 1px solid rgba(255,255,255,0.08);
            border-radius: 24px 24px 0 0;
            padding: 16px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .progress-bar-track {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 999px;
            overflow: hidden;
            height: 8px;
        }
        .progress-bar-fill {
            background: linear-gradient(90deg, #6CB2FF, #8EC5FF);
            border-radius: 999px;
            height: 100%;
            transition: width 0.4s ease;
            box-shadow: 0 0 12px rgba(108,178,255,0.4);
            position: relative;
        }
        .progress-bar-fill::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(255,255,255,0.35), rgba(255,255,255,0.05));
            border-radius: 999px;
        }

        @keyframes fadeInBlur {
            from { opacity: 0; filter: blur(8px); transform: translateY(12px); }
            to { opacity: 1; filter: blur(0); transform: translateY(0); }
        }
        @keyframes pulseGlow {
            0%, 100% { box-shadow: 0 0 16px rgba(108,178,255,0.1); }
            50% { box-shadow: 0 0 32px rgba(108,178,255,0.25); }
        }
        @keyframes shimmer {
            0% { background-position: -200% center; }
            100% { background-position: 200% center; }
        }

        .animate-in {
            animation: fadeInBlur 0.6s ease forwards;
        }
        .animate-pulse-glow {
            animation: pulseGlow 3s ease-in-out infinite;
        }

        .drop-zone-active {
            border-color: rgba(108,178,255,0.5) !important;
            background: rgba(108,178,255,0.06) !important;
            box-shadow: 0 0 32px rgba(108,178,255,0.15), inset 0 0 24px rgba(108,178,255,0.05) !important;
        }

        .status-active { background: rgba(16,185,129,0.12); color: #10B981; border: 1px solid rgba(16,185,129,0.2); }
        .status-expired { background: rgba(239,68,68,0.1); color: #EF4444; border: 1px solid rgba(239,68,68,0.2); }
        .status-exhausted { background: rgba(245,158,11,0.1); color: #F59E0B; border: 1px solid rgba(245,158,11,0.2); }
        .status-revoked { background: rgba(239,68,68,0.1); color: #EF4444; border: 1px solid rgba(239,68,68,0.2); }
        .status-badge { padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; letter-spacing: 0.02em; }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
        ::-webkit-scrollbar-thumb { background: rgba(108,178,255,0.2); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(108,178,255,0.35); }

        @media (max-width: 768px) {
            .taskbar {
                bottom: 12px;
                border-radius: 16px;
                padding: 6px 10px;
                gap: 2px;
                max-width: calc(100vw - 24px);
                overflow-x: auto;
            }
            .taskbar-item { padding: 8px 10px; font-size: 0; }
            .taskbar-item svg { min-width: 20px; }
            .taskbar-orb { width: 36px; height: 36px; }
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body class="min-h-screen antialiased">
    {% block body %}{% endblock %}
    {% block javascripts %}{% endblock %}
</body>
</html>