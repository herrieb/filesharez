{% extends 'app_layout.html.twig' %}

{% block title %}Upload - FileShareZ{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto space-y-6 sm:space-y-7">
    <div class="animate-in">
        <h1 class="text-xl sm:text-2xl font-light tracking-wide text-white/90">Upload</h1>
        <p class="text-white/35 mt-1 text-sm">Share files securely with expiring download links &mdash; resumable from any network hiccup</p>
    </div>

    <div x-data="{ mode: 'file' }" class="space-y-5">
        <div class="flex gap-2">
            <button @click="mode = 'file'"
                :class="mode === 'file' ? 'aero-btn-primary' : 'aero-btn'"
                class="flex-1 sm:flex-none px-4 sm:px-5 py-2 text-sm transition">
                File Upload
            </button>
            <button @click="mode = 'text'"
                :class="mode === 'text' ? 'aero-btn-primary' : 'aero-btn'"
                class="flex-1 sm:flex-none px-4 sm:px-5 py-2 text-sm transition">
                Text Upload
            </button>
        </div>

        <div x-show="mode === 'file'" x-transition>
            <div id="drop-zone"
                class="glass p-8 sm:p-12 text-center cursor-pointer transition-all border-2 border-dashed border-white/8 animate-pulse-glow"
                ondragover="event.preventDefault(); this.classList.add('drop-zone-active')"
                ondragleave="this.classList.remove('drop-zone-active')"
                ondrop="event.preventDefault(); this.classList.remove('drop-zone-active'); handleFiles(event.dataTransfer.files)"
                onclick="document.getElementById('file-input').click()">
                <svg class="w-14 h-14 text-aero/30 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
                <p class="text-white/55 text-base font-light">Drag &amp; drop files here</p>
                <p class="text-white/25 text-sm mt-1">or click to browse &mdash; select multiple files</p>
                <p class="text-white/15 text-xs mt-3">Up to 20GB per file &middot; resumable uploads</p>
            </div>
            <input type="file" id="file-input" class="hidden" multiple onchange="handleFiles(this.files)">
            <div id="file-queue" class="mt-5 space-y-3"></div>

            <div id="aggregate-progress" class="hidden mt-5 glass-panel p-5 space-y-3">
                <div class="flex items-center justify-between">
                    <span class="text-white/60 text-sm font-medium">Overall</span>
                    <span id="aggregate-percent" class="text-aero text-sm font-medium">0%</span>
                </div>
                <div class="progress-bar-track">
                    <div id="aggregate-fill" class="progress-bar-fill" style="width: 0%"></div>
                </div>
                <div class="flex items-center justify-between text-[11px] text-white/40 font-mono">
                    <span><span id="aggregate-bytes">0 B</span> / <span id="aggregate-total">0 B</span></span>
                    <span id="aggregate-speed">&mdash;</span>
                    <span>ETA <span id="aggregate-eta">&mdash;</span></span>
                </div>
            </div>

            <div id="upload-options" class="hidden mt-5 glass-panel p-6 space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Max Downloads</label>
                        <input type="number" id="file-max-downloads" value="1" min="1" max="100" class="form-input w-full">
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Expires in (days)</label>
                        <input type="number" id="file-expiry-days" value="7" min="1" max="30" class="form-input w-full">
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Password (optional)</label>
                    <input type="password" id="file-password" class="form-input w-full" placeholder="Leave empty for no password">
                </div>
                <div>
                    <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Recipient Email (optional)</label>
                    <input type="email" id="file-recipient-email" class="form-input w-full" placeholder="email@example.com">
                </div>
                <div>
                    <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Message (optional)</label>
                    <textarea id="file-message" class="form-input w-full" rows="3" placeholder="Add a message..."></textarea>
                </div>
                <button id="upload-btn" onclick="uploadAllFiles()" class="aero-btn-primary w-full py-3 text-sm">
                    Upload Files
                </button>
            </div>
        </div>

        <div x-show="mode === 'text'" x-transition class="hidden">
            <form id="text-upload-form" class="glass p-8 space-y-5">
                <div class="window-header -mt-8 -mx-8 mb-6">
                    <span class="text-xs text-white/40 uppercase tracking-wider">Text Upload</span>
                    <span></span>
                </div>
                <div>
                    <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Filename</label>
                    <input type="text" id="text-filename" class="form-input w-full" placeholder="notes.txt" required>
                </div>
                <div>
                    <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Content</label>
                    <textarea id="text-content" class="form-input w-full font-mono" rows="8" required></textarea>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Max Downloads</label>
                        <input type="number" id="text-max-downloads" value="1" min="1" max="100" class="form-input w-full">
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Expires in (days)</label>
                        <input type="number" id="text-expiry-days" value="7" min="1" max="30" class="form-input w-full">
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Password (optional)</label>
                    <input type="password" id="text-password" class="form-input w-full" placeholder="Leave empty for no password">
                </div>
                <div>
                    <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Recipient Email (optional)</label>
                    <input type="email" id="text-recipient-email" class="form-input w-full" placeholder="email@example.com">
                </div>
                <button type="submit" id="text-upload-btn" class="aero-btn-primary w-full py-3 text-sm">
                    Create Text Download Link
                </button>
            </form>
        </div>
    </div>

    <div id="upload-success" class="hidden glass p-8 text-center animate-in">
        <div class="w-14 h-14 rounded-full bg-success/10 flex items-center justify-center mx-auto mb-4 border border-success/20">
            <svg class="w-7 h-7 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        </div>
        <h2 class="text-xl font-light text-white/90 mb-1">Upload Complete</h2>
        <p id="success-details" class="text-white/35 text-sm mb-5"></p>
        <div id="success-qr" class="flex justify-center mb-5"></div>
        <div class="glass-light p-4 mb-4">
            <a id="success-url" href="#" class="text-aero hover:text-aero-glow break-all text-sm" target="_blank"></a>
        </div>
        <div class="flex gap-3 justify-center">
            <button onclick="navigator.clipboard.writeText(document.getElementById('success-url').href); this.textContent='Copied!'; setTimeout(() => this.textContent='Copy Link', 2000)"
                class="aero-btn-primary px-8 py-3 text-sm">
                Copy Link
            </button>
            <button onclick="resetUploadForm()" class="aero-btn px-8 py-3 text-sm">
                Upload More
            </button>
        </div>
    </div>
</div>

<style>
.upload-row { transition: all 0.2s ease; }
.upload-row.is-done { border-color: rgba(74,222,128,0.3); }
.upload-row.is-failed { border-color: rgba(239,68,68,0.3); }
.upload-row.is-canceled { opacity: 0.55; }
</style>

<script src="{{ asset('vendor/tus/tus.min.js') }}"></script>
<script>
(function() {
    const RESUMABLE_ENDPOINT = {{ resumableEndpoint|json_encode|raw }};
    const CHUNK_SIZE = 5 * 1024 * 1024; // 5 MB

    let selectedFiles = [];
    let activeUploads = []; // tus.Upload instances

    function b64(str) {
        return btoa(unescape(encodeURIComponent(str)));
    }

    function fmtBytes(n) {
        if (n >= 1073741824) return (n / 1073741824).toFixed(1) + ' GB';
        if (n >= 1048576) return (n / 1048576).toFixed(1) + ' MB';
        if (n >= 1024) return (n / 1024).toFixed(1) + ' KB';
        return n + ' B';
    }

    function fmtSpeed(bps) {
        if (!bps || !isFinite(bps)) return '—';
        return fmtBytes(bps) + '/s';
    }

    function fmtEta(seconds) {
        if (!isFinite(seconds) || seconds < 0) return '—';
        if (seconds < 60) return Math.round(seconds) + 's';
        if (seconds < 3600) return Math.round(seconds / 60) + 'm';
        return Math.round(seconds / 3600) + 'h ' + Math.round((seconds % 3600) / 60) + 'm';
    }

    window.handleFiles = function(files) {
        const queue = document.getElementById('file-queue');
        const options = document.getElementById('upload-options');
        options.classList.remove('hidden');
        for (const file of files) {
            if (selectedFiles.some(f => f.name === file.name && f.size === file.size && f.lastModified === file.lastModified)) continue;
            selectedFiles.push(file);
            const card = document.createElement('div');
            card.className = 'upload-row glass-light p-4 flex items-center gap-4 animate-in';
            card.dataset.fileKey = file.name + ':' + file.size + ':' + file.lastModified;
            card.innerHTML = `
                <div class="w-10 h-10 rounded-xl bg-aero/10 flex items-center justify-center flex-shrink-0 border border-aero/20">
                    <svg class="w-5 h-5 text-aero/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-white/80 font-medium truncate text-sm">${escapeHtml(file.name)}</p>
                    <p class="text-white/35 text-xs row-status">${fmtBytes(file.size)} &middot; queued</p>
                    <div class="progress-bar-track mt-2">
                        <div class="progress-bar-fill row-fill" style="width: 0%"></div>
                    </div>
                    <div class="row-meta text-[11px] text-white/40 font-mono mt-1 flex justify-between">
                        <span class="row-pct">0%</span>
                        <span class="row-speed"></span>
                        <span class="row-eta"></span>
                    </div>
                </div>
                <div class="flex items-center gap-2 flex-shrink-0 row-actions">
                    <button class="aero-btn px-2.5 py-1 text-xs row-pause" style="display:none">Pause</button>
                    <button class="aero-btn px-2.5 py-1 text-xs row-resume" style="display:none">Resume</button>
                    <button class="aero-btn px-2.5 py-1 text-xs row-cancel">Cancel</button>
                </div>
            `;
            queue.appendChild(card);
        }
        document.getElementById('file-input').value = '';
    };

    window.removeFile = function(btn, name, size, lm) {
        const key = name + ':' + size + ':' + lm;
        selectedFiles = selectedFiles.filter(f => (f.name + ':' + f.size + ':' + f.lastModified) !== key);
        const card = btn.closest('.upload-row');
        const upload = activeUploads.find(u => u._card === card);
        if (upload) { try { upload.abort(true); } catch(e){} }
        card.remove();
        if (selectedFiles.length === 0) {
            document.getElementById('upload-options').classList.add('hidden');
        }
    };

    window.uploadAllFiles = async function() {
        if (selectedFiles.length === 0) { alert('Please select at least one file'); return; }
        const btn = document.getElementById('upload-btn');
        btn.disabled = true;
        btn.textContent = 'Starting…';

        const meta = {
            max_downloads: document.getElementById('file-max-downloads')?.value || '1',
            expiry_days: document.getElementById('file-expiry-days')?.value || '7',
            password: document.getElementById('file-password')?.value || '',
            recipient_email: document.getElementById('file-recipient-email')?.value || '',
            message: document.getElementById('file-message')?.value || '',
        };

        const aggregate = document.getElementById('aggregate-progress');
        aggregate.classList.remove('hidden');

        let totalBytes = selectedFiles.reduce((a, f) => a + f.size, 0);
        document.getElementById('aggregate-total').textContent = fmtBytes(totalBytes);

        const startAggregateTimer = (upload) => {
            upload._card._speeds = upload._card._speeds || [];
            upload._card._lastSample = { t: Date.now(), sent: 0 };
        };

        for (const file of selectedFiles) {
            const cardKey = file.name + ':' + file.size + ':' + file.lastModified;
            const card = document.querySelector('.upload-row[data-file-key="' + cssEscape(cardKey) + '"]');
            if (!card) continue;

            card.querySelector('.row-status').textContent = fmtBytes(file.size) + ' · starting…';
            card.querySelector('.row-cancel').onclick = () => {
                const u = activeUploads.find(x => x._card === card);
                if (u) u.abort(true);
            };
            const pauseBtn = card.querySelector('.row-pause');
            const resumeBtn = card.querySelector('.row-resume');

            const upload = new tus.Upload(file, {
                endpoint: RESUMABLE_ENDPOINT,
                chunkSize: CHUNK_SIZE,
                retryDelays: [0, 1000, 3000, 5000, 10000],
                removeFingerprintOnSuccess: true,
                metadata: {
                    filename: file.name,
                    filetype: file.type || 'application/octet-stream',
                    max_downloads: meta.max_downloads,
                    expiry_days: meta.expiry_days,
                    password: meta.password,
                    recipient_email: meta.recipient_email,
                    message: meta.message,
                },
            });
            upload._card = card;
            upload._meta = meta;
            upload._done = false;
            activeUploads.push(upload);
            startAggregateTimer(upload);

            upload.options.onUploadStart = function() {
                card.querySelector('.row-status').textContent = fmtBytes(file.size) + ' · uploading';
            };

            upload.options.onProgress = function(bytesUploaded, bytesTotal) {
                if (upload._done) return;
                const pct = bytesTotal > 0 ? Math.round((bytesUploaded / bytesTotal) * 100) : 0;
                card.querySelector('.row-fill').style.width = pct + '%';
                card.querySelector('.row-pct').textContent = pct + '%';
                const status = card.querySelector('.row-status');
                status.textContent = fmtBytes(bytesUploaded) + ' / ' + fmtBytes(bytesTotal);
                uploadAggregate();
            };

            upload.options.onAfterResponse = function(req, res) {
                // Reached once all chunks are accepted. Call finalize next.
            };

            const finalize = () => {
                if (upload._finalizing) return;
                upload._finalizing = true;
                const status = card.querySelector('.row-status');
                status.textContent = 'Finalizing…';
                fetch(RESUMABLE_ENDPOINT + '/' + upload.url.split('/').pop() + '/finalize', {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        upload._done = true;
                        card.classList.add('is-done');
                        status.textContent = 'Done · ' + data.transfer.filename;
                        card.querySelector('.row-pause').style.display = 'none';
                        card.querySelector('.row-resume').style.display = 'none';
                        card.querySelector('.row-cancel').style.display = 'none';
                        uploadAggregate();
                        if (!activeUploads.some(u => !u._done && !u._canceled && !u._failed)) {
                            showSuccess(data.transfer.downloadUrl, data.transfer.filename + ' — ' + data.transfer.size);
                            btn.disabled = false;
                            btn.textContent = 'Upload Files';
                        }
                    } else {
                        markFailed(card, status, data.error || 'Finalize failed');
                    }
                })
                .catch(err => markFailed(card, status, 'Finalize error: ' + err.message));
            };

            upload.options.onSuccess = function() {
                finalize();
            };

            upload.options.onError = function(err) {
                if (upload._canceled) return;
                markFailed(card, card.querySelector('.row-status'), err.message || 'Upload error');
                btn.disabled = false;
                btn.textContent = 'Upload Files';
            };

            pauseBtn.onclick = () => {
                upload.abort(false);
                pauseBtn.style.display = 'none';
                resumeBtn.style.display = '';
                card.querySelector('.row-status').textContent = 'Paused';
            };
            resumeBtn.onclick = () => {
                resumeBtn.style.display = 'none';
                pauseBtn.style.display = '';
                upload.start();
            };
            pauseBtn.style.display = '';
            resumeBtn.style.display = 'none';

            upload.start();
        }

        function markFailed(card, status, msg) {
            card.classList.add('is-failed');
            status.textContent = 'Failed: ' + msg;
            card.querySelector('.row-pause').style.display = 'none';
            card.querySelector('.row-cancel').style.display = 'none';
        }

        function uploadAggregate() {
            let sent = 0, total = 0, anyRunning = false;
            let speedsPerSec = 0;
            let last = null;
            const now = Date.now();
            for (const u of activeUploads) {
                const f = u.file || (u._card && activeUploads.find(x => x === u) ? null : null);
            }
            // Re-derive: sum over current tus uploads by reading lastResponse/offsetBytes from server via HEAD? Cheaper: ask tus for .options
            for (const u of activeUploads) {
                const file = u.file;
                if (!file) continue;
                total += file.size;
                // Use card DOM for sent bytes:
                const card = u._card;
                if (!card) continue;
                const pctTxt = card.querySelector('.row-pct').textContent;
                const pct = parseFloat(pctTxt) || 0;
                const s = Math.round((pct / 100) * file.size);
                sent += s;
                if (!u._done && !u._canceled && !card.classList.contains('is-failed')) anyRunning = true;
            }
            const fill = document.getElementById('aggregate-fill');
            const pctEl = document.getElementById('aggregate-percent');
            const bytesEl = document.getElementById('aggregate-bytes');
            const totalEl = document.getElementById('aggregate-total');
            const speedEl = document.getElementById('aggregate-speed');
            const etaEl = document.getElementById('aggregate-eta');
            const apct = total > 0 ? Math.round((sent / total) * 100) : 0;
            fill.style.width = apct + '%';
            pctEl.textContent = apct + '%';
            bytesEl.textContent = fmtBytes(sent);
            totalEl.textContent = fmtBytes(total);

            // Compute speed over the last ~1s across all cards
            let totalSpeed = 0;
            for (const u of activeUploads) {
                const card = u._card;
                if (!card || !card._lastSample) continue;
                const dt = (now - card._lastSample.t) / 1000;
                if (dt >= 0.5) {
                    const cur = parseFloat(card.querySelector('.row-pct').textContent) || 0;
                    const curBytes = (cur / 100) * u.file.size;
                    const dBytes = curBytes - card._lastSample.sent;
                    const bps = Math.max(0, dBytes / dt);
                    u._speedBps = bps;
                    card._lastSample = { t: now, sent: curBytes };
                }
                if (u._speedBps) totalSpeed += u._speedBps;
            }
            speedEl.textContent = anyRunning ? fmtSpeed(totalSpeed) : '—';
            const remaining = total - sent;
            const eta = totalSpeed > 0 ? remaining / totalSpeed : Infinity;
            etaEl.textContent = anyRunning ? fmtEta(eta) : '—';
        }

        // Refresh aggregate every 500ms
        setInterval(uploadAggregate, 500);
    };

    function cssEscape(s) {
        return s.replace(/["\\]/g, '\\$&');
    }
    function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }

    window.showSuccess = function(url, details) {
        const success = document.getElementById('upload-success');
        document.getElementById('success-url').href = url;
        document.getElementById('success-url').textContent = url;
        document.getElementById('success-details').textContent = details || 'Your file is ready to share';
        const qrDiv = document.getElementById('success-qr');
        qrDiv.innerHTML = '';
        if (typeof QRCode !== 'undefined') {
            const qrColor = getComputedStyle(document.documentElement).getPropertyValue('--accent-glow').trim() || '#8EC5FF';
            new QRCode(qrDiv, { text: url, width: 120, height: 120, colorDark: qrColor, colorLight: 'transparent', correctLevel: QRCode.CorrectLevel.M });
        }
        success.classList.remove('hidden');
        success.scrollIntoView({ behavior: 'smooth' });
    };

    window.resetUploadForm = function() {
        document.getElementById('upload-success').classList.add('hidden');
        document.getElementById('file-queue').innerHTML = '';
        document.getElementById('upload-options').classList.add('hidden');
        document.getElementById('aggregate-progress').classList.add('hidden');
        selectedFiles = [];
        activeUploads = [];
    };

    document.getElementById('text-upload-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('text-upload-btn');
        btn.disabled = true;
        btn.textContent = 'Creating…';

        const formData = new FormData();
        formData.append('filename', document.getElementById('text-filename').value);
        formData.append('content', document.getElementById('text-content').value);
        formData.append('max_downloads', document.getElementById('text-max-downloads').value);
        formData.append('expiry_days', document.getElementById('text-expiry-days').value);
        formData.append('password', document.getElementById('text-password').value);
        formData.append('recipient_email', document.getElementById('text-recipient-email').value);
        formData.append('message', '');
        try {
            const response = await fetch('/upload/text', { method: 'POST', body: formData });
            const data = await response.json();
            if (data.success) { showSuccess(data.transfer.downloadUrl); }
            else { alert('Upload failed: ' + (data.error || 'Unknown error')); }
        } catch (error) { alert('Upload failed: ' + error.message); }
        finally {
            btn.disabled = false;
            btn.textContent = 'Create Text Download Link';
        }
    });
})();
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js" integrity="sha512-C3AI2BB7K1P7ni7fnRzY2K/C3Kxd9e6X4m64n2GZAgL7qRyJdx6j2L1RP3eD8hMZ9Zz3h47CJq4" crossorigin="anonymous"></script>
{% endblock %}
