{% extends 'app_layout.html.twig' %}

{% block title %}Dashboard - FileShareZ{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto space-y-6 sm:space-y-8">
    <div class="animate-in">
        <h1 class="text-xl sm:text-2xl font-light tracking-wide text-white/90">Dashboard</h1>
        <p class="text-white/35 mt-1 text-sm">Welcome back, {{ app.user.name }}</p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-5">
        <div class="glass-panel p-4 sm:p-5 animate-in" style="animation-delay: 0.1s">
            <p class="text-white/35 text-[10px] sm:text-xs uppercase tracking-wider mb-1">Active Transfers</p>
            <p class="text-2xl sm:text-3xl font-light text-aero-glow">{{ activeTransfers }}</p>
        </div>
        <div class="glass-panel p-4 sm:p-5 animate-in" style="animation-delay: 0.15s">
            <p class="text-white/35 text-[10px] sm:text-xs uppercase tracking-wider mb-1">Expiring Soon</p>
            <p class="text-2xl sm:text-3xl font-light text-warn">{{ expiringSoon }}</p>
        </div>
        <div class="glass-panel p-4 sm:p-5 animate-in" style="animation-delay: 0.2s">
            <p class="text-white/35 text-[10px] sm:text-xs uppercase tracking-wider mb-1">Storage Used</p>
            <p class="text-xl sm:text-3xl font-light text-white/90">
                {{ quotaUsed > 1073741824 ? (quotaUsed / 1073741824)|number_format(1) ~ ' GB' : (quotaUsed / 1048576)|number_format(1) ~ ' MB' }}
            </p>
        </div>
        <div class="glass-panel p-4 sm:p-5 animate-in" style="animation-delay: 0.25s">
            <p class="text-white/35 text-[10px] sm:text-xs uppercase tracking-wider mb-1">Quota</p>
            <p class="text-sm font-medium text-white/70 mt-1">{{ quotaPercent }}% used</p>
            <div class="progress-bar-track mt-3">
                <div class="progress-bar-fill" style="width: {{ min(quotaPercent, 100) }}%"></div>
            </div>
        </div>
    </div>

    <div class="glass animate-in" style="animation-delay: 0.3s">
        <div class="window-header">
            <h2 class="text-sm font-medium text-white/60 uppercase tracking-wider">Recent Transfers</h2>
            <a href="{{ path('app_transfers') }}" class="text-xs text-aero hover:text-aero-glow transition">View all</a>
        </div>
        {% if recentTransfers|length > 0 %}
        <div class="overflow-x-auto table-responsive">
            <table class="w-full">
                <thead>
                    <tr class="text-white/30 text-xs uppercase tracking-wider border-b border-white/5">
                        <th class="px-6 py-3 text-left">Filename</th>
                        <th class="px-6 py-3 text-left">Size</th>
                        <th class="px-6 py-3 text-left">Downloads</th>
                        <th class="px-6 py-3 text-left">Expires</th>
                        <th class="px-6 py-3 text-left">Status</th>
                    </tr>
                </thead>
                <tbody>
                    {% for transfer in recentTransfers %}
                    <tr class="border-b border-white/5 hover:bg-white/[0.03] transition">
                        <td class="px-3 sm:px-6 py-2.5 sm:py-3">
                            <div class="flex items-center gap-2">
                                <span class="text-white/80 font-medium text-sm">{{ transfer.originalFilename }}</span>
                                {% if transfer.isFromLibrary %}
                                    <span class="text-[10px] bg-warn/15 text-warn px-2 py-0.5 rounded-full border border-warn/20">Library</span>
                                {% endif %}
                                {% if transfer.fileRequest %}
                                    <span class="text-[10px] bg-purple-500/15 text-purple-400 px-2 py-0.5 rounded-full border border-purple-500/20">Request</span>
                                {% endif %}
                                {% if transfer.fileCount > 1 %}
                                    <span class="text-[10px] bg-aero/15 text-aero px-2 py-0.5 rounded-full border border-aero/20">{{ transfer.fileCount }}</span>
                                {% elseif transfer.isText %}
                                    <span class="text-[10px] bg-aero/15 text-aero px-2 py-0.5 rounded-full border border-aero/20">Text</span>
                                {% endif %}
                            </div>
                        </td>
                        <td class="px-3 sm:px-6 py-3 text-white/45 text-sm">{{ transfer.formattedSize }}</td>
                        <td class="px-3 sm:px-6 py-3 text-white/45 text-sm">{{ transfer.downloadCount }}/{{ transfer.maxDownloads }}</td>
                        <td class="px-3 sm:px-6 py-3 text-white/45 text-sm">{{ transfer.expiresAt|date('M j, Y') }}</td>
                        <td class="px-3 sm:px-6 py-2.5 sm:py-3">
                            {% if transfer.isDownloadable %}
                                <span class="status-badge status-active">Active</span>
                            {% elseif transfer.isExpired %}
                                <span class="status-badge status-expired">Expired</span>
                            {% else %}
                                <span class="status-badge status-exhausted">Exhausted</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <div class="text-center py-16 text-white/25">
            <svg class="w-14 h-14 mx-auto mb-4 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9"/></svg>
            <p class="text-sm">No transfers yet. Start by uploading a file.</p>
            <a href="{{ path('app_upload') }}" class="aero-btn-primary inline-block mt-4 px-6 py-2.5 text-sm">Upload File</a>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}