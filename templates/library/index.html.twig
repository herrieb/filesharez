{% extends 'app_layout.html.twig' %}

{% block title %}Library - FileShareZ{% endblock %}

{% block content %}
<div class="max-w-6xl mx-auto space-y-7" x-data="{ showAdd: false, shareItem: null }">
    <div class="flex items-center justify-between animate-in">
        <div>
            <h1 class="text-2xl font-light tracking-wide text-white/90">Library</h1>
            <p class="text-white/35 mt-1 text-sm">Share files from your external storage</p>
        </div>
        <button @click="showAdd = !showAdd" class="aero-btn-primary px-5 py-2.5 text-sm flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Add Folder
        </button>
    </div>

    <div id="add-source-panel" x-show="showAdd" x-transition class="glass p-6 space-y-4">
        <h2 class="text-sm font-medium text-white/50 uppercase tracking-wider">Register a folder</h2>
        <p class="text-white/30 text-xs">Enter the absolute server path of a folder you want to make shareable. Folders are scanned one level deep; subdirectories become a single shareable ZIP.</p>
        <form id="add-source-form" class="space-y-3">
            <div>
                <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Display name</label>
                <input type="text" id="src-name" class="form-input w-full" placeholder="e.g. Completed downloads" required>
            </div>
            <div>
                <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Absolute path on the server</label>
                <input type="text" id="src-path" class="form-input w-full font-mono" placeholder="/mnt/data/trnts/complete" required>
            </div>
            <div class="flex gap-2">
                <button type="submit" class="aero-btn-primary px-5 py-2 text-sm">Register & Scan</button>
                <button type="button" @click="showAdd = false" class="aero-btn px-5 py-2 text-sm">Cancel</button>
            </div>
        </form>
    </div>

    {% if sources|length > 0 %}
        <div class="space-y-5">
            {% for source in sources %}
                <div class="glass animate-in" style="animation-delay: {{ loop.index0 * 0.05 }}s">
                    <div class="window-header">
                        <div class="flex items-center gap-3 min-w-0">
                            <svg class="w-4 h-4 text-aero/60 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/></svg>
                            <div class="min-w-0">
                                <h3 class="text-sm font-medium text-white/70">{{ source.name }}</h3>
                                <p class="text-white/30 text-[11px] font-mono truncate">{{ source.path }}</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="text-white/30 text-xs">{{ source.itemCount }} items</span>
                            <span class="text-white/20 text-xs">{{ source.totalSizeBytes > 1073741824 ? (source.totalSizeBytes / 1073741824)|number_format(1) ~ ' GB' : (source.totalSizeBytes / 1048576)|number_format(0) ~ ' MB' }}</span>
                            {% if source.lastScannedAt %}
                                <span class="text-white/20 text-xs">scanned {{ source.lastScannedAt|date('M j, H:i') }}</span>
                            {% endif %}
                            <button onclick="rescanSource('{{ source.id }}', this)" class="aero-btn px-3 py-1.5 text-xs">Rescan</button>
                            <button onclick="deleteSource('{{ source.id }}', this)" class="text-white/30 hover:text-danger text-xs transition">Remove</button>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        <div class="animate-in" style="animation-delay: 0.2s">
            <h2 class="text-sm font-medium text-white/50 uppercase tracking-wider mb-4 px-1">Items</h2>
            {% if items|length > 0 %}
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {% for item in items %}
                        {% set has_token = itemTokens[item.entity.id] is defined %}
                        <div class="glass-panel p-5 flex items-center gap-4">
                            <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0 {% if item.entity.isDirectory %}bg-warn/10 border border-warn/20{% else %}bg-aero/10 border border-aero/20{% endif %}">
                                {% if item.entity.isDirectory %}
                                    <svg class="w-5 h-5 text-warn/70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/></svg>
                                {% else %}
                                    <svg class="w-5 h-5 text-aero/70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                {% endif %}
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-white/80 font-medium text-sm truncate">{{ item.entity.name }}</p>
                                <p class="text-white/30 text-xs">
                                    {{ item.entity.formattedSize }}
                                    {% if item.entity.isDirectory %}<span class="text-warn/60"> &middot; folder (sent as ZIP)</span>{% endif %}
                                </p>
                            </div>
                            <div class="flex items-center gap-2 flex-shrink-0">
                                {% if has_token %}
                                    <button onclick="copyLibraryLink('{{ item.entity.id }}', this)" class="text-white/30 hover:text-aero p-2 transition" title="Copy latest share link">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 0H10m0 0V9m0 4h2m4-4v3"/></svg>
                                    </button>
                                {% endif %}
                                <button @click="shareItem = '{{ item.entity.id }}'; window._sharingItemId = '{{ item.entity.id }}'" class="aero-btn-primary px-4 py-2 text-xs flex-shrink-0">
                                    {% if has_token %}New Link{% else %}Share{% endif %}
                                </button>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="glass p-10 text-center">
                    <p class="text-white/30 text-sm">No items yet. Click "Rescan" on a source.</p>
                </div>
            {% endif %}
        </div>
    {% else %}
        <div class="glass p-16 text-center animate-in">
            <svg class="w-16 h-16 text-white/8 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/></svg>
            <h3 class="text-lg font-light text-white/50">No library sources yet</h3>
            <p class="text-white/25 mt-1 text-sm">Register a folder on your server to start sharing files</p>
            <button @click="showAdd = true" class="aero-btn-primary inline-block mt-6 px-7 py-2.5 text-sm">Register a Folder</button>
        </div>
    {% endif %}

    <div id="share-modal" x-show="shareItem" x-cloak class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/70" @click.self="shareItem = null">
        <div class="glass p-7 w-full max-w-md animate-in">
            <div class="flex items-center justify-between mb-5">
                <h2 class="text-base font-medium text-white/85">Create Share Link</h2>
                <button @click="shareItem = null" class="text-white/30 hover:text-white/60 transition">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <form id="share-form" class="space-y-4">
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Max Downloads</label>
                        <input type="number" name="max_downloads" value="1" min="1" max="100" class="form-input w-full">
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Expires (days)</label>
                        <input type="number" name="expiry_days" value="7" min="1" max="30" class="form-input w-full">
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Password (optional)</label>
                    <input type="password" name="password" class="form-input w-full" placeholder="Leave empty for no password">
                </div>
                <div>
                    <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Recipient Email (optional)</label>
                    <input type="email" name="recipient_email" class="form-input w-full" placeholder="email@example.com">
                </div>
                <div>
                    <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Message (optional)</label>
                    <textarea name="message" class="form-input w-full" rows="2" placeholder="Add a message..."></textarea>
                </div>
                <button type="submit" class="aero-btn-primary w-full py-2.5 text-sm">Create Share Link</button>
            </form>
        </div>
    </div>

    <div id="share-result" class="hidden glass p-7 text-center animate-in" style="max-width: 36rem; margin: 0 auto;">
        <div class="w-12 h-12 rounded-full bg-success/10 flex items-center justify-center mx-auto mb-3 border border-success/20">
            <svg class="w-6 h-6 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        </div>
        <h2 class="text-lg font-light text-white/90 mb-1">Link Created</h2>
        <p class="text-white/35 text-sm mb-4" id="share-result-details"></p>
        <div class="glass-light p-3 mb-4">
            <a id="share-result-url" href="#" class="text-aero hover:text-aero-glow break-all text-sm" target="_blank"></a>
        </div>
        <div class="flex gap-2 justify-center">
            <button id="copy-share-link" class="aero-btn-primary px-6 py-2.5 text-sm">Copy Link</button>
            <button onclick="location.reload()" class="aero-btn px-6 py-2.5 text-sm">Done</button>
        </div>
    </div>
</div>

<style>[x-cloak]{display:none!important;}</style>

<script>
const libraryItemTokens = {{ (itemTokens|default({}))|json_encode|raw }};

function copyLibraryLink(itemId, btn) {
    const token = libraryItemTokens[itemId];
    if (!token) { alert('No share link yet — click "New Link" first.'); return; }
    const url = window.location.origin + '/d/' + token;
    navigator.clipboard.writeText(url);
    const original = btn.innerHTML;
    btn.innerHTML = '<svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
    setTimeout(() => { btn.innerHTML = original; }, 2000);
}

async function rescanSource(id, btn) {
    const orig = btn.textContent;
    btn.disabled = true;
    btn.textContent = '...';
    try {
        const res = await fetch('/library/sources/' + id + '/rescan', { method: 'POST' });
        if (res.ok) location.reload();
        else { alert('Rescan failed'); btn.disabled = false; btn.textContent = orig; }
    } catch(e) { alert('Network error'); btn.disabled = false; btn.textContent = orig; }
}

async function deleteSource(id, btn) {
    if (!confirm('Remove this library source? Files on disk are not touched.')) return;
    try {
        const res = await fetch('/library/sources/' + id + '/delete', { method: 'POST' });
        if (res.ok) location.reload();
        else alert('Delete failed');
    } catch(e) { alert('Network error'); }
}

document.getElementById('add-source-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData();
    formData.append('name', document.getElementById('src-name').value);
    formData.append('path', document.getElementById('src-path').value);
    try {
        const res = await fetch('/library/sources', { method: 'POST', body: formData });
        const data = await res.json();
        if (data.success) location.reload();
        else alert('Failed: ' + (data.error || 'Unknown error'));
    } catch(err) { alert('Failed: ' + err.message); }
});

document.getElementById('share-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const itemId = window._sharingItemId;
    if (!itemId) { alert('No item selected'); return; }
    const form = e.target;
    const formData = new FormData(form);
    try {
        const res = await fetch('/library/items/' + itemId + '/share', { method: 'POST', body: formData });
        const data = await res.json();
        if (data.success) {
            const modal = document.getElementById('share-modal');
            modal.style.display = 'none';
            const result = document.getElementById('share-result');
            result.classList.remove('hidden');
            document.getElementById('share-result-url').href = data.transfer.downloadUrl;
            document.getElementById('share-result-url').textContent = data.transfer.downloadUrl;
            const size = data.transfer.size || '';
            const dirNote = data.transfer.isDirectory ? ' (folder - sent as ZIP)' : '';
            document.getElementById('share-result-details').textContent = data.transfer.filename + ' - ' + size + dirNote;
            const copyBtn = document.getElementById('copy-share-link');
            copyBtn.onclick = () => {
                navigator.clipboard.writeText(data.transfer.downloadUrl);
                copyBtn.textContent = 'Copied!';
                setTimeout(() => copyBtn.textContent = 'Copy Link', 2000);
            };
            result.scrollIntoView({ behavior: 'smooth' });
        } else {
            alert('Failed: ' + (data.error || 'Unknown error'));
        }
    } catch(err) { alert('Failed: ' + err.message); }
});

document.addEventListener('click', (e) => {
    const shareBtn = e.target.closest('button[x\\:click*="shareItem"]');
    if (shareBtn) {
        const m = shareBtn.getAttribute('@click').match(/'([^']+)'/);
        if (m) {
            window._sharingItemId = m[1];
            const modal = document.getElementById('share-modal');
            modal.setAttribute('data-item-id', m[1]);
        }
    }
});
</script>
{% endblock %}
