{% extends 'app_layout.html.twig' %}

{% block title %}Create User - FileShareZ Admin{% endblock %}

{% block content %}
<div class="max-w-lg mx-auto space-y-7">
    <div class="animate-in">
        <h1 class="text-2xl font-light tracking-wide text-white/90">Create User</h1>
        <p class="text-white/35 mt-1 text-sm">Add a new user account</p>
    </div>

    <div class="glass animate-in p-8" style="animation-delay: 0.1s">
        {{ form_start(form, {'attr': {'class': 'space-y-5'}}) }}
            <div>
                {{ form_label(form.name, null, {'label_attr': {'class': 'block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'form-input w-full'}}) }}
                {{ form_errors(form.name) }}
            </div>
            <div>
                {{ form_label(form.email, null, {'label_attr': {'class': 'block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider'}}) }}
                {{ form_widget(form.email, {'attr': {'class': 'form-input w-full'}}) }}
                {{ form_errors(form.email) }}
            </div>
            <div>
                {{ form_label(form.plainPassword, null, {'label_attr': {'class': 'block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider'}}) }}
                {{ form_widget(form.plainPassword, {'attr': {'class': 'form-input w-full'}}) }}
                {{ form_errors(form.plainPassword) }}
            </div>
            <div>
                {{ form_label(form.quotaBytes, null, {'label_attr': {'class': 'block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider'}}) }}
                {{ form_widget(form.quotaBytes, {'attr': {'class': 'form-input w-full'}}) }}
                {{ form_errors(form.quotaBytes) }}
            </div>
            <div>
                <label class="block text-xs font-medium text-white/40 mb-1.5 uppercase tracking-wider">Role</label>
                <div class="space-y-2">
                    {% for child in form.roles %}
                        <label class="flex items-center gap-2 text-white/55 text-sm cursor-pointer">
                            {{ form_widget(child, {'attr': {'class': 'accent-[#6CB2FF]'}}) }}
                            {{ form_label(child) }}
                        </label>
                    {% endfor %}
                </div>
                {{ form_errors(form.roles) }}
            </div>
            <button type="submit" class="aero-btn-primary w-full py-3 text-sm">Create User</button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}