{% extends 'app_layout.html.twig' %}

{% block title %}System Health - FileShareZ Admin{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto space-y-7">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 animate-in">
        <div>
            <h1 class="text-xl sm:text-2xl font-light tracking-wide text-white/90">System Health</h1>
            <p class="text-white/35 mt-1 text-sm">Infrastructure and storage overview</p>
        </div>
        <a href="{{ path('app_admin_dashboard') }}" class="aero-btn px-5 py-2.5 text-sm">Back to Dashboard</a>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-5 animate-in" style="animation-delay: 0.1s">
        <div class="glass-panel p-4 sm:p-5">
            <p class="text-white/35 text-[10px] sm:text-xs uppercase tracking-wider mb-1">Active Transfers</p>
            <p class="text-2xl sm:text-3xl font-light text-aero-glow">{{ activeTransfers }}</p>
            <p class="text-white/25 text-[10px] sm:text-xs mt-1">{{ transferCount }} total, {{ expiredTransfers }} expired</p>
        </div>
        <div class="glass-panel p-4 sm:p-5">
            <p class="text-white/35 text-[10px] sm:text-xs uppercase tracking-wider mb-1">Active Requests</p>
            <p class="text-2xl sm:text-3xl font-light text-white/80">{{ activeFileRequests }}</p>
            <p class="text-white/25 text-[10px] sm:text-xs mt-1">{{ fileRequestCount }} total file requests</p>
        </div>
        <div class="glass-panel p-4 sm:p-5">
            <p class="text-white/35 text-[10px] sm:text-xs uppercase tracking-wider mb-1">Storage Used</p>
            <p class="text-xl sm:text-3xl font-light text-white/80">
                {{ totalStorage > 1073741824 ? (totalStorage / 1073741824)|number_format(1) ~ ' GB' : (totalStorage / 1048576)|number_format(1) ~ ' MB' }}
            </p>
            <p class="text-white/25 text-[10px] sm:text-xs mt-1">DB: {{ (dbSize / 1048576)|number_format(1) }} MB</p>
        </div>
        <div class="glass-panel p-4 sm:p-5">
            <p class="text-white/35 text-[10px] sm:text-xs uppercase tracking-wider mb-1">Disk Free</p>
            <p class="text-xl sm:text-3xl font-light text-white/80">
                {{ diskFree > 1073741824 ? (diskFree / 1073741824)|number_format(1) ~ ' GB' : (diskFree / 1048576)|number_format(1) ~ ' MB' }}
            </p>
            <p class="text-white/25 text-[10px] sm:text-xs mt-1">{{ (diskUsed / diskTotal * 100)|number_format(1) }}% used of {{ (diskTotal / 1073741824)|number_format(1) }} GB</p>
        </div>
    </div>

    <div class="glass-panel p-5 animate-in" style="animation-delay: 0.15s">
        <h2 class="text-sm font-medium text-white/50 uppercase tracking-wider mb-4">Disk Usage</h2>
        <div class="w-full bg-white/5 rounded-full h-3 overflow-hidden">
            <div class="h-3 rounded-full transition-all" style="width: {{ (diskUsed / diskTotal * 100)|number_format(1) }}%; background: linear-gradient(90deg, var(--accent-primary), var(--accent-glow));"></div>
        </div>
        <div class="flex justify-between text-xs text-white/30 mt-2">
            <span>{{ (diskUsed / 1073741824)|number_format(1) }} GB used</span>
            <span>{{ (diskTotal / 1073741824)|number_format(1) }} GB total</span>
        </div>
    </div>

    <div class="glass-panel p-5 sm:p-6 animate-in" style="animation-delay: 0.2s">
        <h2 class="text-sm font-medium text-white/50 uppercase tracking-wider mb-5">System Info</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-3">
            <div class="flex justify-between py-2 border-b border-white/5">
                <span class="text-white/35 text-sm">PHP Version</span>
                <span class="text-white/80 text-sm">{{ phpVersion }}</span>
            </div>
            <div class="flex justify-between py-2 border-b border-white/5">
                <span class="text-white/35 text-sm">Symfony Version</span>
                <span class="text-white/80 text-sm">{{ symfonyVersion }}</span>
            </div>
            <div class="flex justify-between py-2 border-b border-white/5">
                <span class="text-white/35 text-sm">Users</span>
                <span class="text-white/80 text-sm">{{ userCount }}</span>
            </div>
            <div class="flex justify-between py-2 border-b border-white/5">
                <span class="text-white/35 text-sm">Database Size</span>
                <span class="text-white/80 text-sm">{{ (dbSize / 1048576)|number_format(1) }} MB</span>
            </div>
        </div>
    </div>

    {% if userStorage|length > 0 %}
    <div class="glass animate-in" style="animation-delay: 0.25s">
        <div class="window-header">
            <h2 class="text-sm font-medium text-white/60 uppercase tracking-wider">Storage Per User</h2>
        </div>
        <div class="overflow-x-auto table-responsive">
            <table class="w-full">
                <thead>
                    <tr class="text-white/30 text-xs uppercase tracking-wider border-b border-white/5">
                        <th class="px-6 py-3 text-left">User</th>
                        <th class="px-6 py-3 text-left">Transfers</th>
                        <th class="px-6 py-3 text-left">Storage</th>
                        <th class="px-6 py-3 text-left">Usage</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in userStorage %}
                    <tr class="border-b border-white/5 hover:bg-white/[0.03] transition">
                        <td class="px-3 sm:px-6 py-3 text-white/80 text-sm">{{ row.email }}</td>
                        <td class="px-3 sm:px-6 py-3 text-white/45 text-sm">{{ row.transferCount }}</td>
                        <td class="px-3 sm:px-6 py-3 text-white/45 text-sm">
                            {{ row.totalBytes > 1073741824 ? (row.totalBytes / 1073741824)|number_format(1) ~ ' GB' : (row.totalBytes / 1048576)|number_format(1) ~ ' MB' }}
                        </td>
                        <td class="px-3 sm:px-6 py-2.5 sm:py-3" style="min-width: 160px">
                            <div class="w-full bg-white/5 rounded-full h-2 overflow-hidden">
                                <div class="h-2 rounded-full" style="width: {{ totalStorage > 0 ? (row.totalBytes / totalStorage * 100)|number_format(1) : 0 }}%; background: linear-gradient(90deg, var(--accent-primary), var(--accent-glow));"></div>
                            </div>
                            <span class="text-white/25 text-xs">{{ totalStorage > 0 ? (row.totalBytes / totalStorage * 100)|number_format(1) : 0 }}%</span>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}