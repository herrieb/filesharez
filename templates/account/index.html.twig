{% extends 'app_layout.html.twig' %}

{% block title %}Account - FileShareZ{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto space-y-6 sm:space-y-7">
    <div class="animate-in">
        <h1 class="text-xl sm:text-2xl font-light tracking-wide text-white/90">Account</h1>
        <p class="text-white/35 mt-1 text-sm">Manage your account settings</p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 animate-in" style="animation-delay: 0.1s">
        <a href="{{ path('app_account_profile') }}" class="glass-panel p-6 sm:p-7 hover:border-aero/30 transition-all group">
            <div class="w-11 h-11 rounded-xl bg-aero/10 flex items-center justify-center mb-4 group-hover:bg-aero/15 transition border border-aero/15">
                <svg class="w-5 h-5 text-aero/70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            </div>
            <h3 class="text-base font-medium text-white/80 mb-1">Profile</h3>
            <p class="text-white/30 text-sm">Update your display name and email address</p>
        </a>
        <a href="{{ path('app_account_security') }}" class="glass-panel p-6 sm:p-7 hover:border-aero/30 transition-all group">
            <div class="w-11 h-11 rounded-xl bg-aero/10 flex items-center justify-center mb-4 group-hover:bg-aero/15 transition border border-aero/15">
                <svg class="w-5 h-5 text-aero/70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            </div>
            <h3 class="text-base font-medium text-white/80 mb-1">Security</h3>
            <p class="text-white/30 text-sm">Change your password</p>
        </a>
        <a href="{{ path('app_account_library_activity') }}" class="glass-panel p-6 sm:p-7 hover:border-aero/30 transition-all group">
            <div class="w-11 h-11 rounded-xl bg-aero/10 flex items-center justify-center mb-4 group-hover:bg-aero/15 transition border border-aero/15">
                <svg class="w-5 h-5 text-aero/70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-3 4h3"/></svg>
            </div>
            <h3 class="text-base font-medium text-white/80 mb-1">Library Activity</h3>
            <p class="text-white/30 text-sm">See your recent downloads and previews</p>
        </a>
    </div>

    <div class="glass-panel p-6 sm:p-7 animate-in" style="animation-delay: 0.15s">
        <h3 class="text-sm font-medium text-white/50 uppercase tracking-wider mb-5">Account Details</h3>
        <div class="grid gap-4 sm:grid-cols-2 text-sm">
            <div>
                <p class="text-white/30 text-xs uppercase tracking-wider mb-0.5">Display Name</p>
                <p class="text-white/80">{{ user.name }}</p>
            </div>
            <div>
                <p class="text-white/30 text-xs uppercase tracking-wider mb-0.5">Email</p>
                <p class="text-white/80">{{ user.email }}</p>
            </div>
            <div>
                <p class="text-white/30 text-xs uppercase tracking-wider mb-0.5">Role</p>
                <p class="text-white/80">{{ user.isAdmin ? 'Administrator' : 'User' }}</p>
            </div>
            <div>
                <p class="text-white/30 text-xs uppercase tracking-wider mb-0.5">Member Since</p>
                <p class="text-white/80">{{ user.createdAt|date('M j, Y') }}</p>
            </div>
            <div>
                <p class="text-white/30 text-xs uppercase tracking-wider mb-0.5">Storage Used</p>
                <p class="text-white/80">{{ user.usedStorage|format_bytes }} / {{ user.quotaBytes|format_bytes }}</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}